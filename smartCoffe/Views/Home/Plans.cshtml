@model List<WebApplication1.Models.Plan>

@{
    ViewData["Title"] = "Plans";
    Layout = "_Layout";
}

<div class="dashboard-container">

    <h3 class="fw-bold mb-4">
        Subscription Plans
    </h3>

    @foreach (var plan in Model)
    {
        <div class="dashboard-card mb-3">

            <h5>@plan.PlanName</h5>

            <!-- اسم الكوفي -->
            <p class="text-muted mb-1">
                <i class="fa-solid fa-store me-2"></i>
                @plan.CoffeeShopName
            </p>

            <p>
                @plan.CupsPerMonth Cups Per Month
            </p>

            <h3 class="text-success">
                $@plan.Price
            </h3>

            <!-- تحويل المستخدم إلى صفحة الدفع -->
            <form asp-action="Checkout"
                  asp-controller="Payment"
                  method="post">

                <input type="hidden"
                       name="planId"
                       value="@plan.PlanID" />

                <button type="submit"
                        class="primary-btn">
                    Subscribe
                </button>

            </form>

        </div>
    }

</div>