@model List<WebApplication1.Models.CoffeeProduct>

@{
    ViewData["Title"] = "Search";
    Layout = "_Layout";
}

<div class="dashboard-container">

    <h3 class="fw-bold mb-4">
        Coffee Menu
    </h3>

    <div class="row g-3">

        @foreach (var item in Model)
        {
            <div class="col-6">

                <div class="dashboard-card text-center p-3">

                    <i class="fa-solid fa-mug-hot fa-2x text-success mb-2"></i>

                    <h5>@item.ProductName</h5>

                    <small class="text-muted">
                        Cost: @item.CupsCost cup(s)
                    </small>

                    <button class="btn btn-success w-100 mt-3"
                            onclick="orderCoffee(@item.ProductID)">
                        Order
                    </button>

                </div>

            </div>
        }

    </div>

</div>

<script>
    function orderCoffee(productId) {

        fetch('/Coffee/Redeem', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: 'productId=' + productId
        })
        .then(async response => {

            if (response.ok) {
                alert("Coffee ordered successfully ☕");
                location.reload();
            }
            else {
                const msg = await response.text();
                alert(msg);
            }

        });

    }
</script>

<style>
    .dashboard-card {
        transition: 0.2s;
        border-radius: 12px;
    }

        .dashboard-card:hover {
            transform: scale(1.03);
        }
</style>