@model WebApplication1.Models.Plan

@{
    Layout = "_Layout";
}

<div class="dashboard-container text-center">

    <div class="dashboard-card">

        <i class="fa-solid fa-circle-check text-success fa-4x mb-3"></i>

        <h2>
            Payment Successful
        </h2>

        <p>
            Your @Model.PlanName subscription is now active.
        </p>

        <a asp-controller="Home"
               asp-action="Dashboard"
               class="primary-btn">
            Go To Dashboard
        </a>

    </div>

</div>